    "wdio": "wdio run ./wdio.conf.js",
    "test": "wdio ./wdio.conf.js --cucumberOpts.tagExpression",
    "regression": "wdio wdio.conf.js --cucumberOpts.tags='@regression'",
    "core": "wdio wdio.conf.js --cucumberOpts.tags='@core'",
    "uxbuilder": "wdio wdio.conf.js --cucumberOpts.tags='@uxbuilder'",
    "allure": "rmdir /s /q allure-report && npx allure generate ./allure-results -o ./allure-report && npx allure open ./allure-report",
    "apichecks": "cd utils && python -m pytest api_framework_tests_v2.py -q --tb=short --alluredir=../allure-results",
    "apifielo": "cd utils && python -m pytest test_Fielo_API_tests.py -q --tb=short --alluredir=../allure-results",
    "cicd": "cd C:/Chorus Portal Automation_Work/CI_CD && java -jar jenkins.war --httpPort=9090"
  },
